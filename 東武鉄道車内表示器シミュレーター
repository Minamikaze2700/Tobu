<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>3色LED車内案内表示器シミュレーター</title>
    <style>
        body {
            background-color: #d3d3d3;
            color: #fff;
            font-family: sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
        }
        #led-container {
            background-color: #000;
            padding: 1px 150px 3px 80px;
            border-radius: 28px;
        }
        canvas {
            display: block;
            background-color: #000;
        }
        #controls {
            margin-top: 20px;
            width: 100%;
            background: #e1e1e1;
            padding: 15px;
            border-radius: 5px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        }
        .control-group {
            margin-bottom: 12px;
            display: flex;
            align-items: center;
        }
        .control-group label {
            width: 120px;
            color:#000;
            font-weight: bold;
        }
        input[type="text"] {
            flex: 1;
            padding: 6px;
            font-size: 16px;
            background: #111;
            color: #fff;
            border: 1px solid #555;
            border-radius: 4px;
        }
        select, button {
            padding: 6px 12px;
            font-size: 14px;
            background: #747474;
            color: #fff;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            margin-right: 10px;
        }
        select:hover, button:hover {
            background: #666;
        }
        .legend {
            font-size: 12px;
            color: #000;
            margin-top: 5px;
        }
    </style>
</head>
<body>

    <div id="led-container">
        <canvas id="ledCanvas" width="960" height="96"></canvas>
    </div>

    <div id="controls">
        <div class="control-group">
            <label for="inputText">入力テキスト:</label>
            <input type="text" id="inputText">
        </div>
        <div class="legend">
            色指定： &lt;1&gt;黄緑 &nbsp;|&nbsp; &lt;2&gt;赤 &nbsp;|&nbsp; &lt;3&gt;橙 （未指定時は黄緑）
        </div>
        <div class="control-group" style="margin-top: 15px;">
            <label for="alignSelect">表示パターン:</label>
            <select id="alignSelect">
                <option value="left">左寄せ</option>
                <option value="center">中央揃え</option>
                <option value="right">右寄せ</option>
                <option value="scroll">右から左へスクロール</option>
            </select>
            <button id="updateBtn">更新・反映</button>
        </div>
    </div>

